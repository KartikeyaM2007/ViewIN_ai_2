# ==========================================
# LeLo_InterView - Client-Side Firebase Config
# ==========================================
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# ==========================================
# LeLo_InterView - Server-Side Firebase Admin Config
# ==========================================
# Get these from Firebase Console -> Project Settings -> Service Accounts
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your_project.iam.gserviceaccount.com
# Private key must include \n for newlines if single line, e.g. "-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC..."
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----\n"

# ==========================================
# LeLo_InterView - Voice AI (VAPI) Config
# ==========================================
# From Vapi Dashboard Account/API keys
NEXT_PUBLIC_VAPI_WEB_TOKEN=your_vapi_web_token
NEXT_PUBLIC_VAPI_WORKFLOW_ID=your_vapi_assistant_or_workflow_id

# ==========================================
# LeLo_InterView - Generative AI (Google Gemini)
# ==========================================
# From Google AI Studio (aistudio.google.com)
GOOGLE_GENERATIVE_AI_API_KEY=your_google_gemini_api_key
